{
  "name": "ucode-lint",
  "version": "0.1.0",
  "description": "Lint rules for ucode, the OpenWrt scripting language",
  "keywords": [
    "ucode",
    "openwrt",
    "linter",
    "ast-grep",
    "static-analysis"
  ],
  "homepage": "https://github.com/m00qek/ucode-lint#readme",
  "bugs": "https://github.com/m00qek/ucode-lint/issues",
  "repository": "https://github.com/m00qek/ucode-lint",
  "license": "MIT",
  "bin": {
    "ucode-lint": "bin/ucode-lint"
  },
  "scripts": {
    "test": "node --test test/cli.test.js test/parse-rule.test.js test/rules.test.js"
  },
  "files": [
    "bin/ucode-lint",
    "lib/load-grammar.js",
    "lib/parse-rule.js",
    "rules/*.yml",
    "LICENSE"
  ],
  "dependencies": {
    "@ast-grep/napi": "^0.43.0",
    "node-gyp-build": "^4.8.4",
    "tree-sitter-ucode": "^0.2.0",
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "@ast-grep/napi-darwin-arm64": "0.43.0",
    "@ast-grep/napi-darwin-x64": "0.43.0",
    "@ast-grep/napi-linux-arm64-gnu": "0.43.0",
    "@ast-grep/napi-linux-arm64-musl": "0.43.0",
    "@ast-grep/napi-linux-x64-gnu": "0.43.0",
    "@ast-grep/napi-linux-x64-musl": "0.43.0",
    "@ast-grep/napi-win32-arm64-msvc": "0.43.0",
    "@ast-grep/napi-win32-x64-msvc": "0.43.0"
  },
  "engines": {
    "node": ">=18"
  },
  "allowScripts": {
    "tree-sitter-ucode": true
  }
}
