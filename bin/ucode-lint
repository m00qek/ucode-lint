#!/usr/bin/env node
'use strict';

const path = require('node:path');
const fs   = require('node:fs');

let sg;
try {
  sg = require('@ast-grep/napi');
} catch {
  console.error(
    'ucode-lint: could not load @ast-grep/napi — ' +
    'your platform may not have a prebuilt binary.\n' +
    'See https://github.com/m00qek/ucode-lint for supported platforms.'
  );
  process.exit(1);
}

// Register the ucode grammar from tree-sitter-ucode
const grammarDir = path.dirname(require.resolve('tree-sitter-ucode/package.json'));
sg.registerDynamicLanguage({
  ucode: {
    libraryPath: path.join(grammarDir, 'ucode.so'),
    extensions:  ['uc'],
  },
});

// Load and parse rules from rules/ alongside this script
const rulesDir = path.join(__dirname, '..', 'rules');
const rules = fs.readdirSync(rulesDir)
  .filter(f => f.endsWith('.yml'))
  .map(f => parseRule(fs.readFileSync(path.join(rulesDir, f), 'utf8')))
  .filter(Boolean);

// Handle flags
const args = process.argv.slice(2);

if (args.includes('--help') || args.includes('-h')) {
  console.log([
    'Usage: ucode-lint [paths...]',
    '',
    '  Lint ucode source files for common errors, removed JS syntax,',
    '  security issues, and style problems.',
    '',
    '  paths   Files or directories to lint (default: current directory)',
    '',
    'Exit codes:',
    '  0   No errors (warnings may be present)',
    '  1   One or more errors found',
    '',
    'Rules:',
    ...require('node:fs').readdirSync(path.join(__dirname, '..', 'rules'))
      .filter(f => f.endsWith('.yml'))
      .map(f => '  ' + f.replace('.yml', '')),
  ].join('\n'));
  process.exit(0);
}

// Collect .uc files from the given paths (recursive)
const targets = args.filter(a => !a.startsWith('-'));
if (targets.length === 0) targets.push('.');

function collectFiles(target) {
  const stat = fs.statSync(target);
  if (stat.isFile())      return target.endsWith('.uc') ? [target] : [];
  if (stat.isDirectory()) return fs.readdirSync(target, { withFileTypes: true })
    .flatMap(e => collectFiles(path.join(target, e.name)));
  return [];
}

const files = targets.flatMap(collectFiles);
if (files.length === 0) {
  console.log('ucode-lint: no .uc files found');
  process.exit(0);
}

// Run every rule against every file
let errorCount   = 0;
let warningCount = 0;

for (const file of files) {
  const src  = fs.readFileSync(file, 'utf8');
  const root = sg.parse('ucode', src);

  for (const rule of rules) {
    const matches = root.root().findAll(rule.matcher);
    for (const node of matches) {
      const { start } = node.range();
      const severity  = rule.severity;
      console.log(
        `${file}:${start.line + 1}:${start.column + 1}: ` +
        `[${severity}] ${rule.message} (${rule.id})`
      );
      if (severity === 'error') errorCount++;
      else warningCount++;
    }
  }
}

const total = errorCount + warningCount;
console.log(
  `\n${total} problem${total === 1 ? '' : 's'} ` +
  `(${errorCount} error${errorCount === 1 ? '' : 's'}, ` +
  `${warningCount} warning${warningCount === 1 ? '' : 's'}) ` +
  `in ${files.length} file${files.length === 1 ? '' : 's'}.`
);
process.exit(errorCount > 0 ? 1 : 0);

// ---------------------------------------------------------------------------

function parseRule(yaml) {
  const id       = (yaml.match(/^id:\s*(.+)$/m)       || [])[1]?.trim();
  const severity = (yaml.match(/^severity:\s*(.+)$/m) || [])[1]?.trim() ?? 'error';
  const rawMsg   = (yaml.match(/^message:\s*[>|]\n((?:[ \t].+\n?)+)/m) ||
                    yaml.match(/^message:\s*(.+)$/m) || [])[1] ?? id;
  const message  = rawMsg.replace(/\n\s*/g, ' ').trim();

  const matcher = buildMatcher(yaml);
  if (!matcher) return null;

  return { id, severity, message, matcher };
}

function buildMatcher(yaml) {
  // rule:\n  kind: FOO
  const kind = (yaml.match(/^rule:\s*\n\s+kind:\s*(.+)$/m) || [])[1]?.trim();
  if (kind) return { rule: { kind } };

  // rule:\n  pattern: ...
  const pattern = (yaml.match(/^rule:\s*\n\s+pattern:\s*(.+)$/m) || [])[1]?.trim();
  if (pattern) return { rule: { pattern } };

  // rule:\n  any:\n    - pattern: ...\n    - pattern: ...
  const anyBlock = yaml.match(/^rule:\s*\n\s+any:\s*\n((?:\s+-\s+pattern:.+\n?)+)/m);
  if (anyBlock) {
    const patterns = [...anyBlock[1].matchAll(/\s+-\s+pattern:\s*(.+)/g)]
      .map(m => ({ pattern: m[1].trim() }));
    return { rule: { any: patterns } };
  }

  return null;
}
